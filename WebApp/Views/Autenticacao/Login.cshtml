@{
    ViewData["Title"] = "Login";
    ViewData["Layout"] = "Auth";
}

<div class="ats-login-wrapper">
    <div class="ats-login-card">

        <div class="ats-login-brand">
            <i class="bi bi-briefcase-fill"></i>
            <h1>VagasJa!</h1>
            <p class="text-muted">Seu próximo emprego está a uns cliques de distância</p>
        </div>

        <form method="post" id="frmLogin" onsubmit="logar(event, 'txtCredencialLogin', 'txtSenhaLogin')" novalidate>

            <div class="mb-3">
                <label for="txtCredencialLogin" class="form-label fw-semibold">E-mail ou CPF</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                    <input type="text" class="form-control" id="txtCredencialLogin" placeholder="seu@email.com"
                           required onfocusout="validarCredenciaisAcesso('txtCredencialLogin', 'feedbackInvalido');" />
                </div>
            </div>

            <div class="mb-1">
                <label for="txtSenhaLogin" class="form-label fw-semibold">Senha</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <input type="password" class="form-control" id="txtSenhaLogin" placeholder="••••••••" required />
                    <button class="btn btn-outline-secondary" type="button" onclick="visualizarSenha('txtSenhaLogin');" tabindex="-1">
                        <i class="bi bi-eye-slash" id="iconOlhoSenha"></i>
                    </button>
                </div>
            </div>

            <div id="feedbackInvalido" class="invalid-feedback d-block mb-2" style="min-height:1.2em"></div>

            <div class="d-grid mt-3">
                <button class="btn btn-primary btn-lg" type="submit">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Entrar
                </button>
            </div>

            <hr class="my-3" />

            <div class="text-center">
                <a href="@Url.Action("Cadastro", "Autenticacao")" class="btn btn-outline-secondary w-100 mb-2">
                    <i class="bi bi-person-plus me-1"></i> Criar uma conta
                </a>
                <a href="@Url.Action("RecuperacaoSenha", "Autenticacao")" class="link-secondary small">
                    Esqueci minha senha
                </a>
            </div>

        </form>
    </div>
</div>