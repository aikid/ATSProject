@model List<Domain.DTOs.JobResponseDTO>
@{
    ViewData["Title"] = "Vagas";
    ViewData["ActivePage"] = "Vagas";
    var search = ViewData["Search"] as string ?? "";
    var activeFilter = ViewData["ActiveFilter"] as bool?;
}

<div class="ats-page-header mb-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-0">
                <i class="bi bi-file-earmark-text me-2 text-primary"></i>Vagas
            </h2>
            <p class="text-muted mb-0">Gerencie as vagas publicadas</p>
        </div>
        <a href="@Url.Action("Nova", "Vagas")" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Nova vaga
        </a>
    </div>
</div>

<!-- Filtros -->
<div class="ats-card mb-4">
    <div class="ats-card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-12 col-md-6">
                <label class="form-label fw-semibold mb-1">Buscar</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" class="form-control" placeholder="Título, empresa ou localidade..."
                           value="@search" />
                </div>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label fw-semibold mb-1">Status</label>
                <select name="active" class="form-select">
                    @{
                        var statusOpts = new[]
                        {
                            (Value: "true",  Text: "Ativas",   Active: activeFilter == true || !activeFilter.HasValue),
                            (Value: "false", Text: "Inativas", Active: activeFilter == false),
                            (Value: "",      Text: "Todas",    Active: activeFilter == null)
                        };
                    }
                    @foreach (var opt in statusOpts)
                    {
                        if (opt.Active)
                        {
                            <option value="@opt.Value" selected>@opt.Text</option>
                        }
                        else
                        {
                            <option value="@opt.Value">@opt.Text</option>
                        }
                    }
                </select>
            </div>
            <div class="col-12 col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">
                    <i class="bi bi-funnel me-1"></i>Filtrar
                </button>
                <a href="@Url.Action("Index", "Vagas")" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Tabela -->
<div class="ats-card">
    <div class="ats-card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                Nenhuma vaga encontrada.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover ats-table mb-0">
                    <thead>
                        <tr>
                            <th>Vaga</th>
                            <th>Empresa</th>
                            <th>Localidade</th>
                            <th>Criada por</th>
                            <th>Data</th>
                            <th>Status</th>
                            <th class="text-end">Açőes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in Model)
                        {
                            <tr id="row-@job.Id">
                                <td class="fw-semibold">@job.Title</td>
                                <td>@job.Company</td>
                                <td><i class="bi bi-geo-alt text-muted me-1"></i>@job.Location</td>
                                <td>@job.CreatedByName</td>
                                <td class="text-nowrap text-muted" style="font-size:.85rem">
                                    @job.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td>
                                    <span class="badge @(job.IsActive ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")"
                                          id="badge-@job.Id">
                                        @(job.IsActive ? "Ativa" : "Inativa")
                                    </span>
                                </td>
                                <td class="text-end text-nowrap">
                                    <a href="@Url.Action("Editar", "Vagas", new { id = job.Id })"
                                       class="btn btn-sm btn-outline-primary me-1" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <button class="btn btn-sm @(job.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                            title="@(job.IsActive ? "Desativar" : "Ativar")"
                                            id="btn-toggle-@job.Id"
                                            onclick="toggleVaga(@job.Id, this)">
                                        <i class="bi @(job.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    function toggleVaga(id, btn) {
        $.ajax({
            method: 'POST',
            url: '/Vagas/Toggle',
            data: { id: id },
            dataType: 'json'
        }).done(function (res) {
            if (!res.success) {
                notificar(false, 'Erro', res.msg, 'error', '');
                return;
            }
            var badge   = document.getElementById('badge-' + id);
            var isNowActive = badge.classList.contains('bg-secondary-subtle');

            if (isNowActive) {
                badge.className = 'badge bg-success-subtle text-success';
                badge.textContent = 'Ativa';
                btn.className = 'btn btn-sm btn-outline-warning';
                btn.title = 'Desativar';
                btn.innerHTML = '<i class="bi bi-toggle-on"></i>';
            } else {
                badge.className = 'badge bg-secondary-subtle text-secondary';
                badge.textContent = 'Inativa';
                btn.className = 'btn btn-sm btn-outline-success';
                btn.title = 'Ativar';
                btn.innerHTML = '<i class="bi bi-toggle-off"></i>';
            }
        }).fail(function () {
            notificar(false, 'Erro', 'Năo foi possível alterar o status.', 'error', '');
        });
    }
</script>
}
