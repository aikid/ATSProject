@model Domain.DTOs.JobResponseDTO
@{
    ViewData["Title"] = "Editar vaga";
    ViewData["ActivePage"] = "Vagas";
}

<div class="ats-page-header mb-4">
    <div class="d-flex align-items-center gap-2">
        <a href="@Url.Action("Index", "Vagas")" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h2 class="fw-bold mb-0">
                <i class="bi bi-pencil-square me-2 text-primary"></i>Editar vaga
            </h2>
            <p class="text-muted mb-0">Atualize os dados da vaga</p>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-xl-9">
        <form id="frmEditarVaga" novalidate>

            <div class="ats-card mb-4">
                <div class="ats-card-header">
                    <i class="bi bi-info-circle me-2"></i>Informaçőes básicas
                </div>
                <div class="ats-card-body">
                    <div class="row g-3">

                        <div class="col-12">
                            <label for="txtTitle" class="form-label fw-semibold">Título da vaga <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtTitle"
                                   value="@Model.Title" maxlength="200" required />
                            <div id="feedbackInvalido_txtTitle" class="invalid-feedback"></div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label for="txtCompany" class="form-label fw-semibold">Empresa <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-building"></i></span>
                                <input type="text" class="form-control" id="txtCompany"
                                       value="@Model.Company" maxlength="150" required />
                            </div>
                            <div id="feedbackInvalido_txtCompany" class="invalid-feedback"></div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label for="txtLocation" class="form-label fw-semibold">Localidade <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
                                <input type="text" class="form-control" id="txtLocation"
                                       value="@Model.Location" maxlength="150" required />
                            </div>
                            <div id="feedbackInvalido_txtLocation" class="invalid-feedback"></div>
                        </div>

                    </div>
                </div>
            </div>

            <div class="ats-card mb-4">
                <div class="ats-card-header">
                    <i class="bi bi-card-text me-2"></i>Descriçăo da vaga
                </div>
                <div class="ats-card-body">
                    <label for="txtDescription" class="form-label fw-semibold">
                        Descriçăo completa <span class="text-danger">*</span>
                    </label>
                    <textarea class="form-control" id="txtDescription" rows="10" required>@Model.Description</textarea>
                    <div id="feedbackInvalido_txtDescription" class="invalid-feedback"></div>
                    <div class="form-text text-muted mt-1">
                        <span id="charCount">@Model.Description?.Length</span> caracteres
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a href="@Url.Action("Index", "Vagas")" class="btn btn-outline-secondary">
                    Cancelar
                </a>
                <button type="button" class="btn btn-primary" onclick="salvarEdicao(@Model.Id);">
                    <i class="bi bi-check-lg me-1"></i> Salvar alteraçőes
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('txtDescription').addEventListener('input', function () {
        document.getElementById('charCount').textContent = this.value.length;
    });

    function salvarEdicao(id) {
        var title       = document.getElementById('txtTitle');
        var company     = document.getElementById('txtCompany');
        var location    = document.getElementById('txtLocation');
        var description = document.getElementById('txtDescription');

        var campos = [
            { id: 'txtTitle',       valido: title.value.trim().length > 0,         msg: 'Informe o título da vaga.' },
            { id: 'txtCompany',     valido: company.value.trim().length > 0,       msg: 'Informe o nome da empresa.' },
            { id: 'txtLocation',    valido: location.value.trim().length > 0,      msg: 'Informe a localidade.' },
            { id: 'txtDescription', valido: description.value.trim().length >= 20, msg: 'A descriçăo deve ter pelo menos 20 caracteres.' }
        ];

        if (!validarFormulario(campos)) return;

        $.ajax({
            method: 'POST',
            url: '/Vagas/Editar/' + id,
            data: {
                id: id,
                Title: title.value.trim(),
                Company: company.value.trim(),
                Location: location.value.trim(),
                Description: description.value.trim()
            },
            dataType: 'json'
        }).done(function (res) {
            if (res.success) {
                notificar(true, 'Vaga atualizada!', 'As alteraçőes foram salvas com sucesso.', 'success', '/Vagas/Index');
            } else {
                notificar(false, 'Erro', res.msg, 'error', '');
            }
        }).fail(function () {
            notificar(false, 'Erro', 'Năo foi possível salvar as alteraçőes. Tente novamente.', 'error', '');
        });
    }
</script>
}
