@model Domain.DTOs.MyProfileDTO
@{
    ViewData["Title"] = "Meu Perfil";
    ViewData["ActivePage"] = "Perfil";
    var userEmail = Context.Items["Email"] as string ?? "";
}

<div class="ats-page-header mb-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-0">
                <i class="bi bi-person-badge me-2 text-primary"></i>Meu Perfil
            </h2>
            <p class="text-muted mb-0">Mantenha seus dados atualizados para aumentar suas chances</p>
        </div>
        @if (Model.HasProfile)
        {
            <span class="badge bg-success-subtle text-success fs-6 px-3 py-2">
                <i class="bi bi-check-circle me-1"></i>Perfil completo
            </span>
        }
        else
        {
            <span class="badge bg-warning-subtle text-warning fs-6 px-3 py-2">
                <i class="bi bi-exclamation-circle me-1"></i>Perfil incompleto
            </span>
        }
    </div>
</div>

<form id="frmPerfil" novalidate>
<div class="row g-4 align-items-start">

    <!-- COLUNA ESQUERDA -->
    <div class="col-12 col-lg-3">

        <div class="ats-card mb-4 text-center">
            <div class="ats-card-body py-4">
                <div class="perfil-avatar mx-auto mb-3">
                    <i class="bi bi-person-fill"></i>
                </div>
                <div class="fw-bold fs-6">@(Model.ProfileFullName ?? Model.FullName ?? "—")</div>
                <div class="text-muted small">@userEmail</div>
                @if (!string.IsNullOrEmpty(Model.Phone))
                {
                    <div class="text-muted small mt-1">
                        <i class="bi bi-phone me-1"></i>@Model.Phone
                    </div>
                }
            </div>
        </div>

        <div class="ats-card mb-4">
            <div class="ats-card-header"><i class="bi bi-link-45deg me-2"></i>Redes</div>
            <div class="ats-card-body">
                <div class="mb-3">
                    <label for="txtLinkedIn" class="form-label fw-semibold small">LinkedIn</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="bi bi-linkedin"></i></span>
                        <input type="url" class="form-control" id="txtLinkedIn"
                               value="@Model.LinkedIn" maxlength="200"
                               placeholder="linkedin.com/in/voce" />
                    </div>
                </div>
                <div class="mb-0">
                    <label for="txtGitHub" class="form-label fw-semibold small">GitHub</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="bi bi-github"></i></span>
                        <input type="url" class="form-control" id="txtGitHub"
                               value="@Model.GitHub" maxlength="200"
                               placeholder="github.com/voce" />
                    </div>
                </div>
            </div>
        </div>

        <div class="ats-card">
            <div class="ats-card-header"><i class="bi bi-tools me-2"></i>Habilidades</div>
            <div class="ats-card-body">
                <input type="text" class="form-control form-control-sm" id="txtSkills"
                       value="@Model.Skills" placeholder="C#, .NET, React..." />
                <div class="form-text mb-2">Separe por vírgulas.</div>
                <div id="skillsPreview"></div>
            </div>
        </div>

    </div>

    <!-- COLUNA DIREITA -->
    <div class="col-12 col-lg-9">

        <div class="ats-card mb-4">
            <div class="ats-card-header">
                <i class="bi bi-person-circle me-2"></i>Dados da conta
            </div>
            <div class="ats-card-body">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-semibold">E-mail</label>
                        <input type="text" class="form-control" value="@userEmail" disabled />
                        <div class="form-text">O e-mail não pode ser alterado.</div>
                    </div>
                    <div class="col-12 col-md-6">
                        <label for="txtFullName" class="form-label fw-semibold">Nome completo</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input type="text" class="form-control" id="txtFullName"
                                   value="@Model.FullName" maxlength="150" placeholder="Seu nome completo" />
                        </div>
                        <div id="feedbackInvalido_txtFullName" class="invalid-feedback"></div>
                    </div>
                    <div class="col-12 col-md-6">
                        <label for="txtPhone" class="form-label fw-semibold">Telefone</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-phone"></i></span>
                            <input type="tel" class="form-control" id="txtPhone"
                                   value="@Model.Phone" maxlength="15" placeholder="(11) 99999-9999"
                                   oninput="mascaraTelefone(this);" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="ats-card mb-4">
            <div class="ats-card-header">
                <i class="bi bi-briefcase me-2"></i>Perfil profissional
            </div>
            <div class="ats-card-body">
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label for="txtProfileFullName" class="form-label fw-semibold">
                            Nome no currículo <span class="text-danger">*</span>
                        </label>
                        <input type="text" class="form-control" id="txtProfileFullName"
                               value="@Model.ProfileFullName" maxlength="150"
                               placeholder="Nome que aparecerá nas candidaturas" />
                        <div id="feedbackInvalido_txtProfileFullName" class="invalid-feedback"></div>
                    </div>
                    <div class="col-12 col-md-6">
                        <label for="txtProfilePhone" class="form-label fw-semibold">Telefone profissional</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-phone"></i></span>
                            <input type="tel" class="form-control" id="txtProfilePhone"
                                   value="@Model.ProfilePhone" maxlength="15"
                                   placeholder="(11) 99999-9999" oninput="mascaraTelefone(this);" />
                        </div>
                    </div>
                    <div class="col-12">
                        <label for="txtSummary" class="form-label fw-semibold">Resumo profissional</label>
                        <textarea class="form-control" id="txtSummary" rows="4"
                                  placeholder="Descreva brevemente sua experiência e objetivos...">@Model.Summary</textarea>
                        <div class="form-text"><span id="summaryCount">@(Model.Summary?.Length ?? 0)</span> caracteres</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-12 col-xl-6">
                <div class="ats-card h-100">
                    <div class="ats-card-header">
                        <i class="bi bi-building me-2"></i>Experiência profissional
                    </div>
                    <div class="ats-card-body">
                        <textarea class="form-control" id="txtExperience" rows="8"
                                  placeholder="Empresa, cargo e período.">@Model.Experience</textarea>
                    </div>
                </div>
            </div>
            <div class="col-12 col-xl-6">
                <div class="ats-card h-100">
                    <div class="ats-card-header">
                        <i class="bi bi-mortarboard me-2"></i>Formação acadêmica
                    </div>
                    <div class="ats-card-body">
                        <textarea class="form-control" id="txtEducation" rows="8"
                                  placeholder="Instituição, curso e período.">@Model.Education</textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end">
            <button type="button" class="btn btn-primary btn-lg px-5" onclick="salvarPerfil();">
                <i class="bi bi-check-lg me-1"></i>Salvar perfil
            </button>
        </div>

    </div>
</div>
</form>

@section Scripts {
<script>
    document.getElementById('txtSummary').addEventListener('input', function () {
        document.getElementById('summaryCount').textContent = this.value.length;
    });

    document.getElementById('txtSkills').addEventListener('input', renderSkills);
    renderSkills();

    function renderSkills() {
        var preview = document.getElementById('skillsPreview');
        var val = document.getElementById('txtSkills').value;
        preview.innerHTML = val.split(',')
            .map(function(s) { return s.trim(); })
            .filter(function(s) { return s.length > 0; })
            .map(function(s) { return '<span class="badge bg-primary-subtle text-primary me-1 mb-1">' + s + '</span>'; })
            .join('');
    }

    function mascaraTelefone(input) {
        var v = input.value.replace(/\D/g, '').substring(0, 11);
        if (v.length > 10)     v = v.replace(/^(\d{2})(\d{5})(\d{4})$/, '($1) $2-$3');
        else if (v.length > 6) v = v.replace(/^(\d{2})(\d{4,5})(\d{0,4})$/, '($1) $2-$3');
        else if (v.length > 2) v = v.replace(/^(\d{2})(\d+)$/, '($1) $2');
        input.value = v;
    }

    function salvarPerfil() {
        var profileFullName = document.getElementById('txtProfileFullName');
        var fb = document.getElementById('feedbackInvalido_txtProfileFullName');

        if (!profileFullName.value.trim()) {
            exibirFeedback(fb, 'Informe o nome que aparecerá no currículo.', profileFullName);
            profileFullName.scrollIntoView({ behavior: 'smooth', block: 'center' });
            return;
        }
        limparFeedback(fb, profileFullName);

        $.ajax({
            method: 'POST',
            url: '/Perfil/Salvar',
            data: {
                FullName:        document.getElementById('txtFullName').value.trim(),
                Phone:           document.getElementById('txtPhone').value.trim(),
                ProfileFullName: profileFullName.value.trim(),
                ProfilePhone:    document.getElementById('txtProfilePhone').value.trim(),
                LinkedIn:        document.getElementById('txtLinkedIn').value.trim(),
                GitHub:          document.getElementById('txtGitHub').value.trim(),
                Summary:         document.getElementById('txtSummary').value.trim(),
                Skills:          document.getElementById('txtSkills').value.trim(),
                Experience:      document.getElementById('txtExperience').value.trim(),
                Education:       document.getElementById('txtEducation').value.trim()
            },
            dataType: 'json'
        }).done(function (res) {
            if (res.success) {
                notificar(true, 'Perfil salvo!', 'Suas informações foram atualizadas com sucesso.', 'success', '/Perfil');
            } else {
                notificar(false, 'Erro', res.msg, 'error', '');
            }
        }).fail(function () {
            notificar(false, 'Erro', 'Não foi possível salvar o perfil. Tente novamente.', 'error', '');
        });
    }
</script>
}
