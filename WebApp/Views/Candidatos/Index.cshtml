@model List<Domain.DTOs.CandidateListItemDTO>
@{
    ViewData["Title"] = "Candidatos";
    ViewData["ActivePage"] = "Candidatos";
    var search      = ViewData["Search"]      as string ?? "";
    var activeFilter = ViewData["ActiveFilter"] as bool?;
}

<div class="ats-page-header mb-4">
    <div>
        <h2 class="fw-bold mb-0">
            <i class="bi bi-people me-2 text-primary"></i>Candidatos
        </h2>
        <p class="text-muted mb-0">Visualize e gerencie os candidatos cadastrados</p>
    </div>
</div>

<!-- Filtros -->
<div class="ats-card mb-4">
    <div class="ats-card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-12 col-md-7">
                <label class="form-label fw-semibold mb-1">Buscar</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" class="form-control"
                           placeholder="Nome ou e-mail..." value="@search" />
                </div>
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label fw-semibold mb-1">Status</label>
                <select name="active" class="form-select">
                    @{
                        var opts = new[]
                        {
                            (Value: "true",  Text: "Ativos",   Sel: activeFilter == true  || !activeFilter.HasValue),
                            (Value: "false", Text: "Inativos", Sel: activeFilter == false),
                            (Value: "",      Text: "Todos",    Sel: activeFilter == null)
                        };
                    }
                    @foreach (var o in opts)
                    {
                        if (o.Sel) { <option value="@o.Value" selected>@o.Text</option> }
                        else       { <option value="@o.Value">@o.Text</option> }
                    }
                </select>
            </div>
            <div class="col-12 col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">
                    <i class="bi bi-funnel me-1"></i>Filtrar
                </button>
                <a href="@Url.Action("Index", "Candidatos")" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Tabela -->
<div class="ats-card">
    <div class="ats-card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-person-x fs-1 d-block mb-2"></i>
                Nenhum candidato encontrado.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover ats-table mb-0">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>E-mail</th>
                            <th>Telefone</th>
                            <th class="text-center">Perfil</th>
                            <th class="text-center">Candidaturas</th>
                            <th>Status</th>
                            <th class="text-end">Açőes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model)
                        {
                            <tr id="row-@c.Id">
                                <td class="fw-semibold">@(c.FullName ?? "—")</td>
                                <td class="text-muted">@c.Email</td>
                                <td class="text-muted">@(c.Phone ?? "—")</td>
                                <td class="text-center">
                                    @if (c.HasProfile)
                                    {
                                        <span class="badge bg-success-subtle text-success">
                                            <i class="bi bi-check-circle me-1"></i>Sim
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">
                                            <i class="bi bi-dash-circle me-1"></i>Năo
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-primary-subtle text-primary">
                                        @c.ApplicationCount
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @(c.IsActive ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")"
                                          id="badge-@c.Id">
                                        @(c.IsActive ? "Ativo" : "Inativo")
                                    </span>
                                </td>
                                <td class="text-end text-nowrap">
                                    <a href="@Url.Action("Detalhes", "Candidatos", new { id = c.Id })"
                                       class="btn btn-sm btn-outline-primary me-1" title="Ver detalhes">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <button class="btn btn-sm @(c.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                            title="@(c.IsActive ? "Desativar" : "Ativar")"
                                            id="btn-toggle-@c.Id"
                                            onclick="toggleCandidato(@c.Id, this)">
                                        <i class="bi @(c.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    function toggleCandidato(id, btn) {
        $.ajax({
            method: 'POST',
            url: '/Candidatos/Toggle',
            data: { id: id },
            dataType: 'json'
        }).done(function (res) {
            if (!res.success) { notificar(false, 'Erro', res.msg, 'error', ''); return; }

            var badge = document.getElementById('badge-' + id);
            var isNowActive = badge.classList.contains('bg-secondary-subtle');

            if (isNowActive) {
                badge.className = 'badge bg-success-subtle text-success';
                badge.textContent = 'Ativo';
                btn.className = 'btn btn-sm btn-outline-warning';
                btn.title = 'Desativar';
                btn.innerHTML = '<i class="bi bi-toggle-on"></i>';
            } else {
                badge.className = 'badge bg-secondary-subtle text-secondary';
                badge.textContent = 'Inativo';
                btn.className = 'btn btn-sm btn-outline-success';
                btn.title = 'Ativar';
                btn.innerHTML = '<i class="bi bi-toggle-off"></i>';
            }
        }).fail(function () {
            notificar(false, 'Erro', 'Năo foi possível alterar o status.', 'error', '');
        });
    }
</script>
}
