@model Domain.DTOs.CandidateDetailDTO
@{
    ViewData["Title"] = "Detalhes do candidato";
    ViewData["ActivePage"] = "Candidatos";
}

<div class="ats-page-header mb-4">
    <div class="d-flex align-items-center gap-2">
        <a href="@Url.Action("Index", "Candidatos")" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h2 class="fw-bold mb-0">
                <i class="bi bi-person-badge me-2 text-primary"></i>
                @(Model.ProfileFullName ?? Model.FullName ?? Model.Email)
            </h2>
            <p class="text-muted mb-0">Detalhes do candidato</p>
        </div>
        <div class="ms-auto">
            <span class="badge @(Model.IsActive ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary") fs-6"
                  id="badgeStatus">
                @(Model.IsActive ? "Ativo" : "Inativo")
            </span>
            <button class="btn btn-sm @(Model.IsActive ? "btn-outline-warning" : "btn-outline-success") ms-2"
                    id="btnToggle"
                    onclick="toggleCandidato(@Model.Id)">
                <i class="bi @(Model.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                @(Model.IsActive ? "Desativar" : "Ativar")
            </button>
        </div>
    </div>
</div>

<div class="row g-4">

    <!-- Coluna esquerda: dados da conta + perfil -->
    <div class="col-12 col-lg-4">

        <div class="ats-card mb-4">
            <div class="ats-card-header">
                <i class="bi bi-person-circle me-2"></i>Dados da conta
            </div>
            <div class="ats-card-body">
                <dl class="ats-dl">
                    <dt>E-mail</dt>
                    <dd>@Model.Email</dd>

                    <dt>Nome</dt>
                    <dd>@(Model.FullName ?? "—")</dd>

                    <dt>Telefone</dt>
                    <dd>@(Model.Phone ?? "—")</dd>
                </dl>
            </div>
        </div>

        @if (Model.ProfileCreatedAt.HasValue)
        {
            <div class="ats-card mb-4">
                <div class="ats-card-header">
                    <i class="bi bi-link-45deg me-2"></i>Redes
                </div>
                <div class="ats-card-body">
                    <dl class="ats-dl">
                        <dt>LinkedIn</dt>
                        <dd>
                            @if (!string.IsNullOrEmpty(Model.LinkedIn))
                            {
                                <a href="@Model.LinkedIn" target="_blank" class="text-truncate d-block">
                                    <i class="bi bi-box-arrow-up-right me-1"></i>@Model.LinkedIn
                                </a>
                            }
                            else { <span class="text-muted">—</span> }
                        </dd>
                        <dt>GitHub</dt>
                        <dd>
                            @if (!string.IsNullOrEmpty(Model.GitHub))
                            {
                                <a href="@Model.GitHub" target="_blank" class="text-truncate d-block">
                                    <i class="bi bi-box-arrow-up-right me-1"></i>@Model.GitHub
                                </a>
                            }
                            else { <span class="text-muted">—</span> }
                        </dd>
                    </dl>
                </div>
            </div>
        }

    </div>

    <!-- Coluna direita: perfil profissional + candidaturas -->
    <div class="col-12 col-lg-8">

        @if (Model.ProfileCreatedAt.HasValue)
        {
            @if (!string.IsNullOrWhiteSpace(Model.Summary))
            {
                <div class="ats-card mb-4">
                    <div class="ats-card-header">
                        <i class="bi bi-card-text me-2"></i>Resumo profissional
                    </div>
                    <div class="ats-card-body" style="white-space:pre-line">@Model.Summary</div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Skills))
            {
                <div class="ats-card mb-4">
                    <div class="ats-card-header">
                        <i class="bi bi-tools me-2"></i>Habilidades
                    </div>
                    <div class="ats-card-body">
                        @foreach (var skill in Model.Skills.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                        {
                            <span class="badge bg-primary-subtle text-primary me-1 mb-1 fs-6">@skill</span>
                        }
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Experience))
            {
                <div class="ats-card mb-4">
                    <div class="ats-card-header">
                        <i class="bi bi-briefcase me-2"></i>Experięncia
                    </div>
                    <div class="ats-card-body" style="white-space:pre-line">@Model.Experience</div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Education))
            {
                <div class="ats-card mb-4">
                    <div class="ats-card-header">
                        <i class="bi bi-mortarboard me-2"></i>Formaçăo
                    </div>
                    <div class="ats-card-body" style="white-space:pre-line">@Model.Education</div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-warning mb-4">
                <i class="bi bi-exclamation-triangle me-2"></i>
                Este candidato ainda năo preencheu o perfil profissional.
            </div>
        }

        <!-- Candidaturas -->
        <div class="ats-card">
            <div class="ats-card-header">
                <i class="bi bi-send-check me-2"></i>Candidaturas
                <span class="badge bg-primary-subtle text-primary ms-2">@Model.Applications.Count</span>
            </div>
            <div class="ats-card-body p-0">
                @if (!Model.Applications.Any())
                {
                    <div class="text-center py-4 text-muted fst-italic">
                        Nenhuma candidatura registrada.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover ats-table mb-0">
                            <thead>
                                <tr>
                                    <th>Vaga</th>
                                    <th>Empresa</th>
                                    <th>Status</th>
                                    <th>Data</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in Model.Applications)
                                {
                                    <tr>
                                        <td class="fw-semibold">@a.JobTitle</td>
                                        <td class="text-muted">@a.Company</td>
                                        <td>
                                            @{
                                                var (badgeCss, label) = a.Status switch
                                                {
                                                    "Applied"   => ("bg-primary-subtle text-primary",   "Aplicado"),
                                                    "Reviewing" => ("bg-warning-subtle text-warning",   "Em análise"),
                                                    "Approved"  => ("bg-success-subtle text-success",   "Aprovado"),
                                                    "Rejected"  => ("bg-danger-subtle text-danger",     "Reprovado"),
                                                    _           => ("bg-secondary-subtle text-secondary", a.Status)
                                                };
                                            }
                                            <span class="badge @badgeCss">@label</span>
                                        </td>
                                        <td class="text-muted text-nowrap" style="font-size:.85rem">
                                            @a.AppliedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    function toggleCandidato(id) {
        $.ajax({
            method: 'POST',
            url: '/Candidatos/Toggle',
            data: { id: id },
            dataType: 'json'
        }).done(function (res) {
            if (!res.success) { notificar(false, 'Erro', res.msg, 'error', ''); return; }

            var badge  = document.getElementById('badgeStatus');
            var btn    = document.getElementById('btnToggle');
            var isNowActive = badge.classList.contains('bg-secondary-subtle');

            if (isNowActive) {
                badge.className = 'badge bg-success-subtle text-success fs-6';
                badge.textContent = 'Ativo';
                btn.className = 'btn btn-sm btn-outline-warning ms-2';
                btn.innerHTML = '<i class="bi bi-toggle-on"></i> Desativar';
            } else {
                badge.className = 'badge bg-secondary-subtle text-secondary fs-6';
                badge.textContent = 'Inativo';
                btn.className = 'btn btn-sm btn-outline-success ms-2';
                btn.innerHTML = '<i class="bi bi-toggle-off"></i> Ativar';
            }
        }).fail(function () {
            notificar(false, 'Erro', 'Năo foi possível alterar o status.', 'error', '');
        });
    }
</script>
}
